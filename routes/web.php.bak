Route::get('/', [EventsController::class, 'index'])->name('index');

Auth::routes();

Route::get('/admin', [HomeController::class, 'index'])->name('admin');
Route::get('/admin/events', [HomeController::class, 'event_editor'])->name('event-editor');
Route::get('/admin/events/create', [HomeController::class, 'event_create'])->name('event-create');
Route::delete('/admin/events/{event}/delete', [HomeController::class, 'event_delete'])->name('event-delete');
Route::patch('/admin/events/{event}', [HomeController::class, 'event_update'])->name('event-update');
Route::get('/admin/events/edit/{event}', [HomeController::class, 'event_edit'])->name('event-edit');

Route::post('/admin/events', [HomeController::class, 'event_store'])->name('event-store');

Route::get('/{article}', [EventsController::class, 'detail'])->name('detail');